# Rose LiteLLM Gateway — Secrets
# .env lokal anlegen und NICHT ins Git checken!
#
# Generieren:
#   MASTER_KEY=sk-rose-$(python3 -c 'import secrets; print(secrets.token_hex(24))')
#   SALT_KEY=$(python3 -c 'import secrets; print(secrets.token_hex(16))')
#   POSTGRES_PASSWORD=$(python3 -c 'import secrets; print(secrets.token_urlsafe(24))')

MASTER_KEY=sk-rose-REPLACE_WITH_GENERATED_HEX
SALT_KEY=REPLACE_WITH_GENERATED_HEX
POSTGRES_USER=litellm
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD
POSTGRES_DB=litellm
